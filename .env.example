# ────────────── Postgres ──────────────
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://argus:argus@localhost:5432/argus?schema=public

# ────────────── Redis ──────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ────────────── Server ──────────────
SERVER_PORT=4000
JWT_SECRET=replace-with-a-long-random-string
# Token lifetime. Accepts `ms` strings ("7d", "24h", "30m") or "never" to
# mint non-expiring tokens (recommended for long-lived terminal sessions
# — a mid-session re-login would tear down the PTY).
JWT_EXPIRES_IN=never

# Shared secret for the direct sidecar↔server WebSocket (/sidecar-link).
# Used only for terminal PTY traffic; leave blank in local dev (any
# sidecar can connect) and set to a long random string in production.
SIDECAR_LINK_TOKEN=

# Seed admin account (created on first boot if absent)
ADMIN_EMAIL=admin@argus.local
ADMIN_PASSWORD=changeme

# ────────────── Attachments (file / image upload) ──────────────
# Files the user attaches to a turn are stored in an S3-compatible
# object store (the bundled MinIO in docker-compose, or any S3 / R2 /
# MinIO you run). The sidecar never talks to S3 directly — it pulls
# each file over HTTP from the server, which is the S3 gateway — so
# the bucket only needs to be reachable from the server, not from
# remote agent machines.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=argus-attachments
S3_ACCESS_KEY=argus
S3_SECRET_KEY=argus-secret
S3_REGION=us-east-1
# Host ports the bundled MinIO publishes (API + web console).
S3_PORT=9000
S3_CONSOLE_PORT=9001
# Per-file size cap in bytes (default 25 MiB) and max files per turn.
ATTACHMENT_MAX_FILE_BYTES=26214400
ATTACHMENT_MAX_FILES=10

# ────────────── Web ──────────────
# Host port the dashboard is published on by docker-compose. Change it if
# 5173 is already taken on your machine (the SPA still finds the API at
# <hostname>:4000 regardless of this port).
WEB_PORT=5173

# Build-time overrides (Vite inlines these into the bundle). Leave blank
# for the standard runtime-config flow — the docker container reads
# ARGUS_API_URL / ARGUS_WS_URL below at startup and writes them into
# /config.js, which the SPA reads via window.__ARGUS_CONFIG__. The
# build-time vars only exist as a fallback for fully-baked images.
VITE_API_URL=
VITE_WS_URL=

# Runtime config consumed by the published web image's entrypoint
# (deploy/web.entrypoint.sh). Empty values let the SPA derive the API
# URL from the page's own hostname (good for localhost / LAN dev).
# Set to e.g. https://argus-api.example.com for a two-domain prod
# deploy — no rebuild required.
ARGUS_API_URL=
ARGUS_WS_URL=

# ── APNs push notifications (native iOS client) ──────────────────────
# All-or-nothing: leave unset and push is silently disabled (web-only
# deployments need nothing here). Create an APNs auth key (.p8) in the
# Apple Developer portal and set:
#   APNS_TEAM_ID     your Apple developer team id
#   APNS_KEY_ID      the key id of the .p8
#   APNS_KEY_BASE64  base64 of the .p8 file content
#                    (or APNS_KEY_PATH to a mounted file; BASE64 wins)
#   APNS_TOPIC       the app's bundle id (default app.argus.ios)
#   APNS_ENV         sandbox | production (default sandbox — Xcode and
#                    Simulator builds use sandbox; TestFlight/App Store
#                    use production)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_BASE64=
APNS_KEY_PATH=
APNS_TOPIC=
APNS_ENV=
