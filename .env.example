# ────────────── Postgres ──────────────
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://argus:argus@localhost:5432/argus?schema=public

# ────────────── Redis ──────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ────────────── Server ──────────────
SERVER_PORT=4000
JWT_SECRET=replace-with-a-long-random-string
# Token lifetime. Accepts `ms` strings ("7d", "24h", "30m") or "never" to
# mint non-expiring tokens (recommended for long-lived terminal sessions
# — a mid-session re-login would tear down the PTY).
JWT_EXPIRES_IN=never

# Shared secret for the direct sidecar↔server WebSocket (/sidecar-link).
# Used only for terminal PTY traffic; leave blank in local dev (any
# sidecar can connect) and set to a long random string in production.
SIDECAR_LINK_TOKEN=

# Seed admin account (created on first boot if absent)
ADMIN_EMAIL=admin@argus.local
ADMIN_PASSWORD=changeme

# ────────────── Web ──────────────
# Build-time overrides (Vite inlines these into the bundle). Leave blank
# for the standard runtime-config flow — the docker container reads
# ARGUS_API_URL / ARGUS_WS_URL below at startup and writes them into
# /config.js, which the SPA reads via window.__ARGUS_CONFIG__. The
# build-time vars only exist as a fallback for fully-baked images.
VITE_API_URL=
VITE_WS_URL=

# Runtime config consumed by the published web image's entrypoint
# (deploy/web.entrypoint.sh). Empty values let the SPA derive the API
# URL from the page's own hostname (good for localhost / LAN dev).
# Set to e.g. https://argus-api.example.com for a two-domain prod
# deploy — no rebuild required.
ARGUS_API_URL=
ARGUS_WS_URL=
