---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['mock-window', className]} style="--bar-left: 18%; --bar-right: 58%;">
  <div class="mock-titlebar">
    <div class="mock-traffic"><span></span><span></span><span></span></div>
    <div class="ml-2 flex items-center gap-2 text-fg-3 truncate">
      <span class="text-fg-2 font-mono">gpu-box-1</span>
      <span>·</span>
      <span class="font-mono">pty</span>
      <span class="ml-auto inline-flex items-center gap-1.5 shrink-0 text-argus-green/85">
        <span class="relative inline-flex h-1.5 w-1.5">
          <span class="absolute inset-0 rounded-full bg-argus-green animate-pulse-rim"></span>
        </span>
        <span class="font-mono text-[11px]">attached</span>
      </span>
    </div>
  </div>

  <!-- Terminal body — ANSI-styled htop-ish output -->
  <div class="bg-bg-0/70 px-5 py-5 font-mono text-[11.5px] leading-[1.5] text-fg-1 min-h-[280px]">
    <!-- htop-like header -->
    <div class="flex items-center justify-between text-fg-3 pb-1">
      <span><span class="text-argus-green">CPU</span>[<span class="text-argus-green">||||||||||||</span><span class="text-fg-3">............</span>] <span class="text-fg-1">42.7%</span></span>
      <span><span class="text-argus-green">MEM</span>[<span class="text-argus-green">|||||||</span><span class="text-fg-3">.................</span>] <span class="text-fg-1">11.2G/64G</span></span>
    </div>
    <div class="text-fg-3">Tasks: <span class="text-fg-1">312</span>, 4 running · Load: <span class="text-fg-1">3.41 2.88 2.04</span> · Up: 14d 7h</div>

    <div class="mt-2 grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-3 text-[10.5px] uppercase tracking-[0.12em]">
      <span>PID</span><span>USER</span><span>CPU%</span><span>COMMAND</span><span class="text-right">MEM</span>
    </div>

    <div class="grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-2">
      <span>14082</span><span>root</span><span class="text-argus-green">98.3</span><span class="text-fg-1 truncate">python -m train --gpus 4 --bs 32</span><span class="text-right">8.4G</span>
    </div>
    <div class="grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-2">
      <span>14083</span><span>root</span><span class="text-argus-green">94.1</span><span class="text-fg-1 truncate">cuda-streamd</span><span class="text-right">2.1G</span>
    </div>
    <div class="grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-2">
      <span>11401</span><span>argus</span><span>2.4</span><span class="truncate">argus-sidecar --listen :7641</span><span class="text-right">38M</span>
    </div>
    <div class="grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-2">
      <span>11402</span><span>argus</span><span>0.9</span><span class="truncate">codex --resume 92e1f0… --print</span><span class="text-right">112M</span>
    </div>
    <div class="grid grid-cols-[60px_60px_70px_1fr_60px] text-fg-3">
      <span>1234</span><span>www-data</span><span>0.1</span><span class="truncate">caddy reload --config /etc/caddy</span><span class="text-right">14M</span>
    </div>

    <div class="mt-3 border-t border-[oklch(0.18_0_0)] pt-2 text-fg-3 text-[11px]">
      <span>F1 </span><span class="text-fg-1">Help</span>
      <span class="ml-3">F2 </span><span class="text-fg-1">Setup</span>
      <span class="ml-3">F3 </span><span class="text-fg-1">Search</span>
      <span class="ml-3">F9 </span><span class="text-fg-1">Kill</span>
      <span class="ml-3">F10</span><span class="text-fg-1">Quit</span>
    </div>

    <!-- Cursor on a fresh prompt line at bottom -->
    <div class="mt-3 flex items-center text-fg-1">
      <span class="text-argus-green">argus@gpu-box-1</span>:<span class="text-argus-rim">~/work</span>$&nbsp;<span class="inline-block h-3 w-[8px] bg-argus-green/85 align-middle animate-cursor-blink"></span>
    </div>
  </div>
</div>
