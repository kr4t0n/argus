---
import FileTreeMock from './FileTreeMock.astro';
import MachineRow from '../primitives/MachineRow.astro';
import ToolRow from '../primitives/ToolRow.astro';

interface Props {
  variant?: 'hero' | 'flat';
  class?: string;
}
const { variant = 'flat', class: className = '' } = Astro.props;

// Real argus uses lucide for machine icons + lobehub brand icons for
// agent types. The mock uses simple mono glyphs to imply the type
// without trying to reproduce branded marks pixel-for-pixel.
---

<div class:list={['mock-window', className]} data-variant={variant} style="--bar-left: 36%; --bar-right: 20%;">
  <!-- Window titlebar (chrome) -->
  <div class="mock-titlebar">
    <div class="mock-traffic">
      <span></span><span></span><span></span>
    </div>
    <div class="ml-2 flex items-center gap-2 text-fg-3 truncate">
      <span class="font-mono text-fg-2">metrics-endpoint</span>
      <span class="hidden sm:inline">·</span>
      <span class="hidden sm:inline truncate font-mono">claude-code · gpu-box-1</span>
      <span class="ml-auto inline-flex items-center gap-1.5 shrink-0">
        <span class="relative inline-flex h-1.5 w-1.5">
          <span class="absolute inset-0 rounded-full bg-argus-green animate-pulse-rim"></span>
        </span>
        <span class="text-argus-green text-[11px]">live</span>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-[220px_1fr_200px] min-h-[420px]" style="--panel-divider: var(--bg-0);">
    <!-- =================================
         Left sidebar — argus pattern:
         brand strip → agents+sessions → machines
         ================================= -->
    <aside class="flex flex-col" style="border-right: 1px solid var(--panel-divider); background: transparent;">
      <!-- Brand strip -->
      <div class="h-10 px-3 flex items-center justify-between shrink-0" style="border-bottom: 1px solid var(--panel-divider);">
        <div class="flex items-center gap-2">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inset-0 rounded-full bg-argus-green animate-pulse-rim"
              style="box-shadow: 0 0 8px oklch(0.78 0.17 158 / 0.55);"></span>
          </span>
          <span class="text-fg-0 text-[12px] font-semibold tracking-tight">Argus</span>
        </div>
        <div class="flex items-center gap-2 text-fg-3">
          <!-- theme toggle glyph -->
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <!-- collapse glyph -->
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
        </div>
      </div>

      <!-- Agents -->
      <div class="flex-1 px-1 py-2 space-y-1.5 text-[11.5px] overflow-hidden">
        <!-- Agent: claude-code "metrics" (active, expanded) -->
        <div>
          <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-fg-0">
            <!-- Claude (lobehub brand) -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="oklch(0.74 0.16 38)" aria-hidden="true">
              <path d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z" fill-rule="nonzero"/>
            </svg>
            <span class="font-mono">metrics</span>
            <span class="ml-auto relative inline-flex h-1.5 w-1.5">
              <span class="absolute inset-0 rounded-full bg-argus-green animate-pulse-rim"></span>
            </span>
          </div>
          <div class="ml-4 mt-1 space-y-0.5 border-l pl-2" style="border-color: var(--bg-0);">
            <div class="px-2 py-1 rounded text-fg-0 text-[11px]" style="background: oklch(0.78 0.17 158 / 0.10);">metrics endpoint</div>
            <div class="px-2 py-1 text-fg-3 text-[11px] truncate">soft-archive bug</div>
          </div>
        </div>

        <!-- Agent: codex "release" -->
        <div>
          <div class="flex items-center gap-2 px-2 py-1.5 text-fg-1 rounded-md">
            <!-- Codex (lobehub brand) -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
              <path clip-rule="evenodd" d="M8.086.457a6.105 6.105 0 013.046-.415c1.333.153 2.521.72 3.564 1.7a.117.117 0 00.107.029c1.408-.346 2.762-.224 4.061.366l.063.03.154.076c1.357.703 2.33 1.77 2.918 3.198.278.679.418 1.388.421 2.126a5.655 5.655 0 01-.18 1.631.167.167 0 00.04.155 5.982 5.982 0 011.578 2.891c.385 1.901-.01 3.615-1.183 5.14l-.182.22a6.063 6.063 0 01-2.934 1.851.162.162 0 00-.108.102c-.255.736-.511 1.364-.987 1.992-1.199 1.582-2.962 2.462-4.948 2.451-1.583-.008-2.986-.587-4.21-1.736a.145.145 0 00-.14-.032c-.518.167-1.04.191-1.604.185a5.924 5.924 0 01-2.595-.622 6.058 6.058 0 01-2.146-1.781c-.203-.269-.404-.522-.551-.821a7.74 7.74 0 01-.495-1.283 6.11 6.11 0 01-.017-3.064.166.166 0 00.008-.074.115.115 0 00-.037-.064 5.958 5.958 0 01-1.38-2.202 5.196 5.196 0 01-.333-1.589 6.915 6.915 0 01.188-2.132c.45-1.484 1.309-2.648 2.577-3.493.282-.188.55-.334.802-.438.286-.12.573-.22.861-.304a.129.129 0 00.087-.087A6.016 6.016 0 015.635 2.31C6.315 1.464 7.132.846 8.086.457zm-.804 7.85a.848.848 0 00-1.473.842l1.694 2.965-1.688 2.848a.849.849 0 001.46.864l1.94-3.272a.849.849 0 00.007-.854l-1.94-3.393zm5.446 6.24a.849.849 0 000 1.695h4.848a.849.849 0 000-1.696h-4.848z"/>
            </svg>
            <span class="font-mono">release</span>
            <span class="ml-auto h-1.5 w-1.5 rounded-full" style="background: oklch(0.42 0 0);"></span>
          </div>
          <div class="ml-4 mt-0.5 space-y-0.5 border-l pl-2" style="border-color: var(--bg-0);">
            <div class="px-2 py-1 text-fg-3 text-[11px] truncate">helm 0.1.11 bump</div>
          </div>
        </div>

        <!-- Agent: cursor-cli "fleet-config" -->
        <div>
          <div class="flex items-center gap-2 px-2 py-1.5 text-fg-1 rounded-md">
            <!-- Cursor (lobehub brand) -->
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" aria-hidden="true">
              <path d="M22.106 5.68L12.5.135a.998.998 0 00-.998 0L1.893 5.68a.84.84 0 00-.419.726v11.186c0 .3.16.577.42.727l9.607 5.547a.999.999 0 00.998 0l9.608-5.547a.84.84 0 00.42-.727V6.407a.84.84 0 00-.42-.726zm-.603 1.176L12.228 22.92c-.063.108-.228.064-.228-.061V12.34a.59.59 0 00-.295-.51l-9.11-5.26c-.107-.062-.063-.228.062-.228h18.55c.264 0 .428.286.296.514z"/>
            </svg>
            <span class="font-mono">fleet-config</span>
            <span class="ml-auto h-1.5 w-1.5 rounded-full" style="background: oklch(0.42 0 0);"></span>
          </div>
        </div>
      </div>

      <!-- Machines -->
      <div class="shrink-0 px-1 py-2" style="border-top: 1px solid var(--panel-divider);">
        <div class="flex items-center px-2 pb-1.5">
          <span class="text-[10px] uppercase tracking-[0.18em] text-fg-3">machines</span>
          <span class="ml-1.5 text-[10px] text-fg-3">(4)</span>
        </div>
        <div class="space-y-0 text-[11px]">
          <MachineRow name="laptop" status="idle" icon="laptop" />
          <MachineRow name="gpu-box-1" status="live" icon="cpu" />
          <MachineRow name="home-srv" status="idle" icon="server" />
          <MachineRow name="dev-vm-east" status="idle" icon="cloud" />
        </div>
      </div>
    </aside>

    <!-- =================================
         Main stream
         ================================= -->
    <main class="px-6 md:px-14 py-8 leading-[1.6] flex flex-col gap-2.5">
      <!-- Convo content stays narrow + centered so the panel breathes. -->
      <div class="mx-auto w-full max-w-[480px] flex flex-col gap-2.5">
      <!-- User turn -->
      <div class="text-fg-2 text-[11.5px]">
        <span class="text-fg-3 mr-2 select-none">›</span>
        Add a <span class="code-chip">/metrics</span> endpoint to <span class="code-chip">apps/server</span> with prom-client counters for stream chunks and active sessions.
      </div>

      <!-- Assistant turn -->
      <p class="text-fg-1 text-[12px] leading-[1.6]">Reading the bootstrap, then wiring up <span class="code-chip">prom-client</span> as a Nest middleware.</p>

      <!-- Tool pill: Read (collapsed). NO rim — flat tinted bg. -->
      <ToolRow icon="file" verb="Read" arg="apps/server/src/main.ts" meta="68 lines" />

      <!-- Tool pill: Edit (expanded with diff) — outline only, uniform bg -->
      <div class="rounded-md text-[12px]" style="border: 1px solid var(--bg-0);">
        <div class="px-3 py-1.5 flex items-center gap-2">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-argus-green shrink-0"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <span class="text-fg-0 font-medium">Edit</span>
          <span class="font-mono text-fg-1 truncate">apps/server/src/main.ts</span>
          <span class="ml-auto text-argus-green/95 text-[10.5px]">+8 −0</span>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-fg-2 rotate-180 shrink-0"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="px-4 py-2.5 font-mono text-[11.5px] leading-[1.7]" style="background: transparent; border-top: 1px solid var(--bg-0);">
          <div class="text-violet-300/80">@@ -22,6 +22,14 @@</div>
          <div class="text-fg-2"><span class="select-none">  </span>const app = await NestFactory.create(AppModule);</div>
          <div class="text-emerald-200" style="background: oklch(0.55 0.20 152 / 0.13);"><span class="select-none">+ </span>const registry = new client.Registry();</div>
          <div class="text-emerald-200" style="background: oklch(0.55 0.20 152 / 0.13);"><span class="select-none">+ </span>client.collectDefaultMetrics(&#123; register: registry &#125;);</div>
          <div class="text-emerald-200" style="background: oklch(0.55 0.20 152 / 0.13);"><span class="select-none">+ </span>app.use('/metrics', metricsHandler(registry));</div>
        </div>
      </div>

      <!-- Tool pill: Bash (collapsed, success) -->
      <ToolRow icon="terminal" verb="Bash" arg="curl -s localhost:3000/metrics | head -3" meta="✓ exit 0" metaTone="green" />

      <!-- Closing assistant text -->
      <p class="text-fg-1 text-[12px] leading-[1.6]">
        <span class="code-chip">/metrics</span> live on port 3000. Default Node metrics plus custom counters <span class="code-chip">argus_stream_chunks_total</span> and <span class="code-chip">argus_active_sessions</span>.<span
          class="inline-block ml-1 -mb-0.5 h-3 w-[7px] bg-argus-green/90 animate-cursor-blink"></span>
      </p>
      </div>
    </main>

    <!-- =================================
         Right panel: working dir
         ================================= -->
    <aside class="px-3.5 py-4 text-[11px]" style="border-left: 1px solid var(--panel-divider); background: transparent;">
      <div class="px-1 pb-1.5 flex items-center justify-between">
        <span class="uppercase tracking-[0.18em] text-fg-3 text-[10px]">Working dir</span>
        <span class="font-mono text-fg-3 text-[10px] inline-flex items-center gap-1">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-argus-green/80"><path d="M6 3v12"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
          <span class="text-argus-green/85">main</span>
        </span>
      </div>
      <FileTreeMock />
    </aside>
  </div>
</div>

<style>
  [data-variant="hero"] {
    transform: perspective(2400px) rotateX(8deg) rotateY(-3deg) rotateZ(0.4deg);
    transform-origin: 50% 0%;
  }
  @media (max-width: 768px) {
    [data-variant="hero"] {
      transform: none;
    }
  }
</style>

<!--
  Inline component-like fragments below.
  Astro can't define components mid-file, so these are just markup
  patterns — kept here as comments for readers; the real ones are
  rendered inline above. The "MachineRow" / "ToolRow" placeholders in
  the markup above will fail to compile because Astro looks for an
  imported component. We swap them to inline markup below.
-->
