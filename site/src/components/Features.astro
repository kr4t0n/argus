---
import TerminalMock from './mocks/TerminalMock.astro';
import FileViewMock from './mocks/FileViewMock.astro';
import SessionsMock from './mocks/SessionsMock.astro';
---

<section id="features" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-page px-6">
    <header class="max-w-prose">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-fg-3 mb-4">§03 · In the box</p>
      <h2 class="text-h2 font-medium text-fg-0 text-balance">A dashboard that feels like a local IDE.</h2>
    </header>

    <!-- Highlight 1 — File preview -->
    <div class="mt-20 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-5">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-argus-green/80 mb-4">Working dir</p>
        <h3 class="text-h3 text-fg-0 font-medium max-w-[18ch] text-balance">Live tree of the remote box.</h3>
        <p class="mt-4 text-fg-1 text-pretty max-w-[52ch]">
          Lazy-expanding, gitignore-aware, kept fresh by <span class="code-chip">fsnotify</span>. Branch badge in the header.
        </p>
      </div>
      <div class="lg:col-span-7 mesh-stage">
        <div class="mesh-bg-soft" aria-hidden="true"></div>
        <FileViewMock />
      </div>
    </div>

    <div class="my-24 lg:my-32"></div>

    <!-- Highlight 2 — PTY terminal (mock left, text right) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-7 lg:order-1 order-2 mesh-stage">
        <div class="mesh-bg-soft" aria-hidden="true"></div>
        <TerminalMock />
      </div>
      <div class="lg:col-span-5 lg:order-2 order-1">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-argus-green/80 mb-4">PTY terminal</p>
        <h3 class="text-h3 text-fg-0 font-medium max-w-[20ch] text-balance">A real shell on the remote box.</h3>
        <p class="mt-4 text-fg-1 text-pretty max-w-[52ch]">
          Opt in per agent. <span class="code-chip">vim</span>, <span class="code-chip">htop</span>, <span class="code-chip">k9s</span>: usable. Sub-10 ms keystroke echo.
        </p>
      </div>
    </div>

    <div class="my-24 lg:my-32"></div>

    <!-- Highlight 3 — Sessions = conversations -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-5">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-argus-green/80 mb-4">Sessions = conversations</p>
        <h3 class="text-h3 text-fg-0 font-medium max-w-[20ch] text-balance">Pick up where you left off.</h3>
        <p class="mt-4 text-fg-1 text-pretty max-w-[52ch]">
          Long-lived threads tied to the CLI's <span class="code-chip">--resume</span> ids. Soft-archive when done, restore when it comes back.
        </p>
      </div>
      <div class="lg:col-span-7 mesh-stage">
        <div class="mesh-bg-soft" aria-hidden="true"></div>
        <SessionsMock />
      </div>
    </div>
  </div>
</section>
