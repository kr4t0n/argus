---
interface Props {
  icon: 'file' | 'edit' | 'terminal' | 'search' | 'glob';
  verb: string;
  arg: string;
  meta?: string;
  metaTone?: 'default' | 'green';
}
const { icon, verb, arg, meta, metaTone = 'default' } = Astro.props;
---

<div class="rounded-md flex items-center gap-2 px-3 py-1.5 text-[12px]" style="border: 1px solid var(--bg-0);">
  {icon === 'file' && (
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-fg-3 shrink-0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
  )}
  {icon === 'edit' && (
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-fg-3 shrink-0"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
  )}
  {icon === 'terminal' && (
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-fg-3 shrink-0"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
  )}
  {icon === 'search' && (
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-fg-3 shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  )}
  {icon === 'glob' && (
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-fg-3 shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  )}

  <span class="text-fg-1">{verb}</span>
  <span class="font-mono text-fg-2 truncate">{arg}</span>

  {meta && (
    <span
      class:list={[
        'ml-auto text-[10.5px] shrink-0',
        metaTone === 'green' ? 'text-argus-green' : 'text-fg-3',
      ]}
    >{meta}</span>
  )}

  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-fg-3 shrink-0"><polyline points="6 9 12 15 18 9"/></svg>
</div>
