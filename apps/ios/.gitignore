# SwiftPM (commit Package.resolved when generated — it pins dependencies)
.build/
.swiftpm/

# Xcode (the app project, Info.plist, and entitlements are generated by
# XcodeGen — `xcodegen generate` in ArgusApp/; never commit them)
*.xcodeproj/
ArgusApp/Info.plist
ArgusApp/ArgusApp.entitlements
# Per-developer XcodeGen overrides (team id, push entitlement)
ArgusApp/local.yml
xcuserdata/
DerivedData/

# macOS
.DS_Store
