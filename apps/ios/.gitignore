# SwiftPM (commit Package.resolved when generated — it pins dependencies)
.build/
.swiftpm/

# Xcode (the app project, Info.plist, and entitlements are generated by
# XcodeGen — `xcodegen generate` in Argus/; never commit them)
*.xcodeproj/
Argus/Info.plist
Argus/Argus.entitlements
xcuserdata/
DerivedData/

# macOS
.DS_Store
