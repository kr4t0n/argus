// Argus control plane — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("admin") // admin | viewer
  createdAt    DateTime  @default(now())
  // Free-form rules text the user wants every CLI agent they spawn
  // to follow (coding style, banned patterns, project conventions).
  // Rendered + edited from the dashboard's user panel; the sidecar
  // reads the latest value at agent boot to inject into adapters as
  // an `AGENTS.md` / `CLAUDE.md` / `--rules` flag (sync path is a
  // follow-up). NULL = "no rules set" — distinct from "" so a future
  // "clear rules" gesture has a target.
  rules        String?   @db.Text
  // Opt-in extensions the user has enabled, as a JSON map of
  // extension-id → boolean (e.g. {"notes": true}). An account-level
  // preference so toggling on one browser is reflected everywhere —
  // unlike device-local UI state (theme, notification permission)
  // which stays in the browser. JSON rather than a column-per-extension
  // so adding an extension needs no migration. NULL = nothing enabled.
  extensions   Json?

  sessions     Session[]
  projectNotes ProjectNote[]
}

// A free-form note the user keeps for a "project" — the
// (machineId, workingDir) pair every session in that directory
// shares. Projects have no first-class row of their own (the sidebar
// derives them from agents' workingDirs), so the note is keyed by the
// triple directly. One note per (user, machine, workingDir): editing
// from any session in that directory edits the same note. Unlike
// User.rules these are personal scratch, never synced to sidecars.
model ProjectNote {
  id         String   @id @default(cuid())
  userId     String
  machineId  String
  workingDir String
  notes      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([userId, machineId, workingDir])
  @@index([machineId])
}

// A Machine is a host running one argus-sidecar process. The sidecar
// self-registers on boot via MachineRegisterEvent; the dashboard then
// creates Agent rows as children of this machine and the server pushes
// them down via control commands.
//
// `name` is what the user sees in the sidebar — by default it's the
// machine's hostname (Bonjour `.local` suffix stripped). Operators can
// override at `argus-sidecar init` time.
model Machine {
  id                String   @id @default(uuid())
  name              String   @unique
  hostname          String
  os                String   // darwin | linux
  arch              String   // amd64 | arm64
  sidecarVersion    String
  // Json shape: [{ "type": "claude-code", "binary": "claude", "version": "1.2.3" }, ...]
  availableAdapters Json
  status            String   @default("offline") // online | offline
  // User-chosen icon glyph (one of MachineIcon's CATALOG keys, e.g.
  // "server-cog"). Null falls back to the default in the UI. Lives on
  // Machine itself rather than a per-user table because everyone in
  // the workspace should see the same icon for the same host — it's
  // metadata, not preference.
  iconKey           String?
  lastSeenAt        DateTime
  registeredAt      DateTime @default(now())
  archivedAt        DateTime?
  // Sticky soft-delete tombstone. Distinct from `archivedAt`, which
  // the machine-register handler resets to null on every re-register
  // (a live sidecar un-archives itself). `deletedAt` is never cleared
  // by the lifecycle consumer: once set, register/heartbeat events
  // from that sidecar are ignored, so a still-running or restarting
  // sidecar can no longer resurrect the machine. A deleted machine is
  // filtered out of every active query. NO child rows are removed —
  // its agents are soft-hidden via their own `archivedAt`, and the
  // sessions/commands/chunks/terminals underneath survive so history
  // stays viewable through the normal session UI.
  deletedAt         DateTime?

  agents       Agent[]
  quotas       MachineAgentQuota[]
  projectNotes ProjectNote[]

  @@index([status])
  @@index([archivedAt])
  @@index([deletedAt])
}

// MachineAgentQuota stores the latest plan-quota snapshot one sidecar
// has reported for (machine, agent type, signed-in account). The
// sidecar probes each installed CLI's on-disk OAuth file every few
// minutes and forwards the result inside machine-heartbeat events;
// this table caches the most recent successful (or unsuccessful)
// snapshot.
//
// Why three columns in the unique key (and not just two):
//   - Quota is fundamentally an *account*-level concept, not a
//     machine-level one. Two machines signed into the same Anthropic
//     account see the same numbers; two different accounts on the
//     same machine over time are genuinely different observations.
//   - `fingerprint` is the sidecar's stable per-account hash (sha256
//     of "argus-quota-fp-v1:<source>:<vendor account id>"). It's
//     opaque to the server — we store and key on it but never reverse
//     it. Empty string means "no signed-in account on this machine"
//     (a tombstone the sidecar emits after a logout); tombstones from
//     different machines all hash to the same key '' but live in
//     their own group at aggregation time, so they never outrank a
//     real-account row from another machine via `checkedAt`.
//
// `windows` carries an array of `QuotaWindow` records (see
// `packages/shared-types/src/protocol.ts::QuotaWindow`). `error` is
// non-empty when the probe ran but failed (vendor 4xx/5xx, expired
// token, unparseable response) — we keep the row anyway so the
// dashboard can render an "unknown" badge with the reason in a
// tooltip rather than silently hiding a misconfigured CLI.
model MachineAgentQuota {
  id          String   @id @default(cuid())
  machineId   String
  agentType   String   // matches AgentType — "claude-code" | "codex" | "cursor-cli" | …
  source      String   // "claude-code-oauth" | "codex-chatgpt" | "cursor-workos" | …
  // Stable per-account hash. Empty string is the tombstone sentinel —
  // "this machine isn't signed in for this agentType right now."
  fingerprint String
  windows     Json
  error       String?  @db.Text
  // Sidecar wallclock when the probe ran. Used to break ties when
  // multiple sidecars report the same (agentType, fingerprint) — the
  // freshest report wins.
  checkedAt DateTime
  updatedAt DateTime @updatedAt

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([machineId, agentType, fingerprint])
  @@index([agentType, fingerprint])
}

model Agent {
  // Server-generated UUID. Returned by POST /machines/:id/agents and
  // pushed to the sidecar via CreateAgentCommand.
  id               String    @id @default(uuid())
  // User-friendly label, unique within a single machine.
  name             String
  machineId        String
  type             String
  status           String    @default("offline") // online | offline | busy | error
  supportsTerminal Boolean   @default(false)
  version          String?
  workingDir       String?
  lastHeartbeatAt  DateTime
  registeredAt     DateTime
  archivedAt       DateTime? // soft-hide from sidebar; preserves history.

  machine   Machine    @relation(fields: [machineId], references: [id], onDelete: Cascade)
  sessions  Session[]
  commands  Command[]
  terminals Terminal[]

  @@unique([machineId, name])
  @@index([status])
  @@index([type])
  @@index([archivedAt])
  @@index([machineId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  agentId    String
  title      String
  externalId String?
  status     String   @default("active") // active | idle | done | failed
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  commands Command[]

  @@index([userId, updatedAt])
  @@index([agentId, updatedAt])
  @@index([userId, archivedAt])
}

model Command {
  id          String    @id @default(cuid())
  sessionId   String
  agentId     String
  kind        String    @default("execute") // execute | cancel
  prompt      String?   @db.Text
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  // Normalized TokenUsage (shared-types/usage.ts) for this command's
  // final chunk, written by the ingestor when the turn finalizes.
  // NULL means "no usage" — either the turn hasn't finished yet, or
  // it ended without a usage payload (cancellation, error, custom
  // adapter that doesn't emit one). /me/usage SUMs this column to
  // avoid scanning every final chunk's raw `meta` JSON.
  usage       Json?

  session Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agent   Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks  ResultChunk[]

  @@index([sessionId, createdAt])
  @@index([agentId, createdAt])
}

model ResultChunk {
  id        String   @id @default(cuid())
  commandId String
  seq       Int
  kind      String
  delta     String?  @db.Text
  content   String?  @db.Text
  meta      Json?
  ts        DateTime @default(now())

  command Command @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId, seq])
}

// Audit row for an interactive PTY session opened against an agent.
// We do NOT persist the keystroke transcript here; that would balloon
// fast and risks capturing secrets typed into the shell. Add a separate
// transcript table later if you need replay/forensics.
model Terminal {
  id          String    @id @default(cuid())
  agentId     String
  userId      String
  status      String    @default("opening") // opening | open | closed | error
  shell       String
  cwd         String?
  cols        Int       @default(120)
  rows        Int       @default(32)
  exitCode    Int?
  closeReason String?   @db.Text
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, openedAt])
  @@index([userId, openedAt])
  @@index([status])
}
