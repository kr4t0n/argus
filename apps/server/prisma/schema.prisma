// Argus control plane — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("admin") // admin | viewer
  createdAt    DateTime  @default(now())
  // Free-form rules text the user wants every CLI agent they spawn
  // to follow (coding style, banned patterns, project conventions).
  // Rendered + edited from the dashboard's user panel; the sidecar
  // reads the latest value at agent boot to inject into adapters as
  // an `AGENTS.md` / `CLAUDE.md` / `--rules` flag (sync path is a
  // follow-up). NULL = "no rules set" — distinct from "" so a future
  // "clear rules" gesture has a target.
  rules        String?   @db.Text
  // Opt-in extensions the user has enabled, as a JSON map of
  // extension-id → boolean (e.g. {"notes": true}). An account-level
  // preference so toggling on one browser is reflected everywhere —
  // unlike device-local UI state (theme, notification permission)
  // which stays in the browser. JSON rather than a column-per-extension
  // so adding an extension needs no migration. NULL = nothing enabled.
  extensions   Json?

  sessions     Session[]
  projectNotes ProjectNote[]
  attachments  Attachment[]
  apiKeys      ApiKey[]
  deviceTokens DeviceToken[]
  liveActivityTokens LiveActivityToken[]
}

// One push-notification endpoint (an APNs device token today) owned by
// a user. Registered by native clients via POST /me/devices; the push
// service fans task-completion alerts out to every row a user has.
// Tokens are globally unique — re-registering a token under another
// account re-homes it (a device has exactly one owner). Rows are
// deleted on logout (client-driven), on APNs "Unregistered"/
// "BadDeviceToken" feedback (server-driven), and with the user
// (cascade).
model DeviceToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String   @default("ios")
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt

  @@index([userId])
}

// One ActivityKit push token — PER-ACTIVITY, not per-device: the iOS
// client starts a Live Activity for a running turn and registers the
// activity's token against the session so the result-ingestor can push
// content-state updates ('liveactivity' APNs type) while the phone is
// locked. Rows die with the activity: the client deletes on end, and
// APNs 410/BadDeviceToken feedback prunes strays (an ended activity's
// token starts rejecting).
model LiveActivityToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// Long-lived, revocable credential for machine-to-machine callers
// (dashboards, integrations) — an alternative to the human email/password
// → JWT flow. Unlike a JWT, a key can be revoked (`revokedAt`) without
// rotating JWT_SECRET (which would log out every human), and carries a
// `readonly` flag the auth guard enforces by HTTP method. The plaintext
// secret is shown ONCE at creation and never stored: only its SHA-256
// `hash` lives here (a fast hash is fine — keys are high-entropy random
// tokens, not low-entropy passwords, so no bcrypt needed, and the unique
// hash gives an O(1) indexed lookup on verify). A key always acts AS a
// user, so per-user scoping (e.g. a caller's own sessions) is unchanged.
model ApiKey {
  id         String    @id @default(cuid())
  // Human label shown in the management UI, e.g. "dashboard".
  name       String
  // First chars of the plaintext (e.g. "argus_AbCd12"), stored so the UI
  // can identify a key after creation without ever revealing the secret.
  prefix     String
  // SHA-256 hex of the full plaintext key. Unique so verify is a single
  // indexed findUnique rather than a scan-and-compare.
  hash       String    @unique
  // The user this key authenticates as.
  userId     String
  // When true, the auth guard rejects any non-GET/HEAD/OPTIONS request.
  readonly   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  // Bumped (best-effort) on each successful verify, for "last used" UI.
  lastUsedAt DateTime?
  // Optional hard expiry. NULL = never expires.
  expiresAt  DateTime?
  // Soft revocation tombstone. NULL = active; set = rejected on verify.
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A free-form note the user keeps for a "project" — the
// (machineId, workingDir) pair every session in that directory
// shares. Projects have no first-class row of their own (the sidebar
// derives them from agents' workingDirs), so the note is keyed by the
// triple directly. One note per (user, machine, workingDir): editing
// from any session in that directory edits the same note. Unlike
// User.rules these are personal scratch, never synced to sidecars.
model ProjectNote {
  id         String   @id @default(cuid())
  userId     String
  machineId  String
  workingDir String
  notes      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([userId, machineId, workingDir])
  @@index([machineId])
}

// Server-side metadata for a "project" — the (machineId, workingDir)
// pair every session in that directory shares. Projects still have no
// first-class lifecycle (the sidebar derives rows from agents'
// workingDirs plus client-local placeholders); this row exists for
// metadata that must roam across browsers. Today that's just the
// user-picked icon glyph (a single A-Z letter), workspace-shared like
// Machine.iconKey — metadata, not preference. Reset keeps the row with
// iconKey NULL: the (machineId, workingDir) identity is the natural
// anchor if placeholders are ever promoted server-side.
model Project {
  id         String   @id @default(cuid())
  machineId  String
  workingDir String
  iconKey    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  machine  Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([machineId, workingDir])
  @@index([machineId])
}

// A Machine is a host running one argus-sidecar process. The sidecar
// self-registers on boot via MachineRegisterEvent; the dashboard then
// creates Agent rows as children of this machine and the server pushes
// them down via control commands.
//
// `name` is what the user sees in the sidebar — by default it's the
// machine's hostname (Bonjour `.local` suffix stripped). Operators can
// override at `argus-sidecar init` time.
model Machine {
  id                String   @id @default(uuid())
  name              String   @unique
  hostname          String
  os                String   // darwin | linux
  arch              String   // amd64 | arm64
  sidecarVersion    String
  // Json shape: [{ "type": "claude-code", "binary": "claude", "version": "1.2.3" }, ...]
  availableAdapters Json
  status            String   @default("offline") // online | offline
  // User-chosen icon glyph (one of MachineIcon's CATALOG keys, e.g.
  // "server-cog"). Null falls back to the default in the UI. Lives on
  // Machine itself rather than a per-user table because everyone in
  // the workspace should see the same icon for the same host — it's
  // metadata, not preference.
  iconKey           String?
  lastSeenAt        DateTime
  registeredAt      DateTime @default(now())
  archivedAt        DateTime?
  // Sticky soft-delete tombstone. Distinct from `archivedAt`, which
  // the machine-register handler resets to null on every re-register
  // (a live sidecar un-archives itself). `deletedAt` is never cleared
  // by the lifecycle consumer: once set, register/heartbeat events
  // from that sidecar are ignored, so a still-running or restarting
  // sidecar can no longer resurrect the machine. A deleted machine is
  // filtered out of every active query. NO child rows are removed —
  // its agents are soft-hidden via their own `archivedAt`, and the
  // sessions/commands/chunks/terminals underneath survive so history
  // stays viewable through the normal session UI.
  deletedAt         DateTime?

  agents       Agent[]
  quotas       MachineAgentQuota[]
  projectNotes ProjectNote[]
  projects     Project[]

  @@index([status])
  @@index([archivedAt])
  @@index([deletedAt])
}

// MachineAgentQuota stores the latest plan-quota snapshot one sidecar
// has reported for (machine, agent type, signed-in account). The
// sidecar probes each installed CLI's on-disk OAuth file every few
// minutes and forwards the result inside machine-heartbeat events;
// this table caches the most recent successful (or unsuccessful)
// snapshot.
//
// Why three columns in the unique key (and not just two):
//   - Quota is fundamentally an *account*-level concept, not a
//     machine-level one. Two machines signed into the same Anthropic
//     account see the same numbers; two different accounts on the
//     same machine over time are genuinely different observations.
//   - `fingerprint` is the sidecar's stable per-account hash (sha256
//     of "argus-quota-fp-v1:<source>:<vendor account id>"). It's
//     opaque to the server — we store and key on it but never reverse
//     it. Empty string means "no signed-in account on this machine"
//     (a tombstone the sidecar emits after a logout); tombstones from
//     different machines all hash to the same key '' but live in
//     their own group at aggregation time, so they never outrank a
//     real-account row from another machine via `checkedAt`.
//
// `windows` carries an array of `QuotaWindow` records (see
// `packages/shared-types/src/protocol.ts::QuotaWindow`). `error` is
// non-empty when the probe ran but failed (vendor 4xx/5xx, expired
// token, unparseable response) — we keep the row anyway so the
// dashboard can render an "unknown" badge with the reason in a
// tooltip rather than silently hiding a misconfigured CLI.
model MachineAgentQuota {
  id          String   @id @default(cuid())
  machineId   String
  agentType   String   // matches AgentType — "claude-code" | "codex" | "cursor-cli" | …
  source      String   // "claude-code-oauth" | "codex-chatgpt" | "cursor-workos" | …
  // Stable per-account hash. Empty string is the tombstone sentinel —
  // "this machine isn't signed in for this agentType right now."
  fingerprint String
  windows     Json
  error       String?  @db.Text
  // Sidecar wallclock when the probe ran. Used to break ties when
  // multiple sidecars report the same (agentType, fingerprint) — the
  // freshest report wins.
  checkedAt DateTime
  updatedAt DateTime @updatedAt

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([machineId, agentType, fingerprint])
  @@index([agentType, fingerprint])
}

model Agent {
  // Server-generated UUID. Returned by POST /machines/:id/agents and
  // pushed to the sidecar via CreateAgentCommand.
  id               String    @id @default(uuid())
  // User-friendly label, unique within a single machine.
  name             String
  machineId        String
  type             String
  status           String    @default("offline") // online | offline | busy | error
  supportsTerminal Boolean   @default(false)
  version          String?
  workingDir       String?
  lastHeartbeatAt  DateTime
  registeredAt     DateTime
  archivedAt       DateTime? // soft-hide from sidebar; preserves history.
  // Stored model catalog: {source, models: ModelCatalogEntry[]}.
  // Written by the sidecar's unsolicited push at supervisor spawn and
  // by every on-demand fetch; read by GET /agents/:id/models so the
  // picker never waits on a live CLI exec. modelCatalogAt drives the
  // stale-while-revalidate threshold. NULL = never probed.
  modelCatalog     Json?
  modelCatalogAt   DateTime?

  machine   Machine    @relation(fields: [machineId], references: [id], onDelete: Cascade)
  sessions  Session[]
  commands  Command[]
  terminals Terminal[]

  @@unique([machineId, name])
  @@index([status])
  @@index([type])
  @@index([archivedAt])
  @@index([machineId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  agentId    String
  // Phase 1 of the agent→runner refactor (docs/plan-agent-to-runners.md):
  // sessions carry their own (project, CLI) identity so later phases can
  // route without the Agent row. `projectId` anchors the session to its
  // (machineId, workingDir) pair — pinned at creation because claude-code
  // and cursor keep resume state on disk keyed by the cwd, so a session's
  // workdir must never change after the first turn. NULL on both = a
  // pre-backfill row whose agent had no workingDir (the sidebar's
  // per-machine "no project" bucket). `agentId` stays authoritative for
  // dispatch until Phase 3/4 retire it.
  projectId  String?
  cliType    String?
  title      String
  externalId String?
  status     String   @default("active") // active | idle | failed (lifecycle only)
  // Unread-result marker, orthogonal to `status`. True when a turn
  // reached a terminal state (idle=success, failed=error) the user may
  // not have seen; cleared on open (markSeen). The sidebar shows a dot
  // iff `unread`, colored by `status`. See SessionStatus / unread in
  // packages/shared-types.
  unread     Boolean  @default(false)
  // Session-default ModelSelection (shared-types) merged into every
  // turn's Command.options at dispatch (per-turn override wins).
  // NULL = "CLI default" — no model flags passed, pre-feature behavior.
  modelSelection Json?
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // SetNull (not Cascade): a machine hard-delete already removes
  // sessions through the Agent cascade; losing just a Project row must
  // never take conversation history with it.
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  commands Command[]

  @@index([userId, updatedAt])
  @@index([agentId, updatedAt])
  @@index([userId, archivedAt])
  @@index([projectId, updatedAt])
}

model Command {
  id          String    @id @default(cuid())
  sessionId   String
  agentId     String
  kind        String    @default("execute") // execute | cancel
  prompt      String?   @db.Text
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  // Normalized TokenUsage (shared-types/usage.ts) for this command's
  // final chunk, written by the ingestor when the turn finalizes.
  // NULL means "no usage" — either the turn hasn't finished yet, or
  // it ended without a usage payload (cancellation, error, custom
  // adapter that doesn't emit one). /me/usage SUMs this column to
  // avoid scanning every final chunk's raw `meta` JSON.
  usage       Json?
  // The adapter options this turn was dispatched with (session default
  // merged with any per-turn override) — primarily the ModelSelection
  // keys. NULL for pre-feature rows and turns sent with no options.
  // Recorded so history shows what each turn actually ran with.
  options     Json?

  session     Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agent       Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  chunks      ResultChunk[]
  attachments Attachment[]

  @@index([sessionId, createdAt])
  @@index([agentId, createdAt])
}

// A file the user attached to a turn. Bytes live in S3/MinIO under
// `s3Key`; this row is the metadata + ownership record. Uploaded ahead
// of the turn via POST /attachments (so `commandId` is NULL until the
// turn is actually sent), then linked to its Command at dispatch. The
// sidecar pulls the bytes over HTTP, lands them under the agent's
// `.argus/uploads/`, and references the path in the prompt.
//
// Deleting a Command cascades these rows away; the S3 object is removed
// best-effort by the service on that path (orphan sweep is a follow-up).
// `commandId IS NULL` rows are unlinked uploads (composer abandoned
// before send) and are safe to prune by age.
model Attachment {
  id        String   @id @default(cuid())
  userId    String
  commandId String?
  filename  String
  mime      String
  size      Int
  s3Key     String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  command Command? @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId])
  @@index([userId, createdAt])
}

model ResultChunk {
  id        String   @id @default(cuid())
  commandId String
  seq       Int
  kind      String
  delta     String?  @db.Text
  content   String?  @db.Text
  meta      Json?
  ts        DateTime @default(now())

  command Command @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId, seq])
}

// Audit row for an interactive PTY session opened against an agent.
// We do NOT persist the keystroke transcript here; that would balloon
// fast and risks capturing secrets typed into the shell. Add a separate
// transcript table later if you need replay/forensics.
model Terminal {
  id          String    @id @default(cuid())
  agentId     String
  userId      String
  status      String    @default("opening") // opening | open | closed | error
  shell       String
  cwd         String?
  cols        Int       @default(120)
  rows        Int       @default(32)
  exitCode    Int?
  closeReason String?   @db.Text
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, openedAt])
  @@index([userId, openedAt])
  @@index([status])
}
